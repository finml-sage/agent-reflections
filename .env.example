# Agent Reflections — Context Source Configuration
#
# Session source (required — has sensible defaults)
REFLECT_SESSION_DIR=~/.claude/projects/
REFLECT_SESSION_DEPTH=10

# Memory files — markdown files from agent-memory or similar
# Path to directory containing .md files; count = how many to randomly sample
REFLECT_MEMORY_PATH=
REFLECT_MEMORY_COUNT=5

# Proverbs — wisdom/principles files
REFLECT_PROVERBS_PATH=
REFLECT_PROVERBS_COUNT=3

# Rules — operational rules/constraints
REFLECT_RULES_PATH=
REFLECT_RULES_COUNT=3

# Extensible extra sources — add as many as needed
# Pattern: REFLECT_EXTRA_SOURCE_N + REFLECT_EXTRA_COUNT_N
# REFLECT_EXTRA_SOURCE_1=
# REFLECT_EXTRA_COUNT_1=2
# REFLECT_EXTRA_SOURCE_2=
# REFLECT_EXTRA_COUNT_2=2

# LLM configuration (used by downstream layers, not this module)
REFLECT_MODEL=grok-4-1-fast-reasoning
REFLECT_API_KEY_FILE=~/.xai.env
